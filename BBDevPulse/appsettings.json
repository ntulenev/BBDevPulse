    "ExcludeWeekend": true,
    "ExcludedDays": [
      "01.01.2026",
      "02.01.2026",
    ],
    "PeopleCsvPath": "team.csv", //optional CSV enrichment: Name;Grade;Department
    "TeamFilter": "Platform",
    "ShowDeveloperUuidInStats": true,
    "ShowAllDetailsForDevelopers": true,
    "RepoNameFilter": "XXX.",
    "BranchNameList": [
      //"develop",
      //"master"
    ],
    "Pdf": {
      "Enabled": true,
      "OutputPath": "export-bbdevpulse-report.pdf"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "System.Net.Http.HttpClient": "Warning",
      "Microsoft": "Warning"
    }
  }
