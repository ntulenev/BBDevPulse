{
  "Bitbucket": {
    "FromDate": "2026-03-01", // Alternative to Days: inclusive start date
    "ToDate": "2026-03-14",   // Alternative to Days: inclusive end date
    "Workspace": "",
    "PageLength": 50,
    "PullRequestConcurrency": 2,
    "RepositoryConcurrency": 2,
    "Username": "",
    "AppPassword": "",
    "RepoSearchMode": "SearchByFilter", //FilterFromTheList or SearchByFilter
